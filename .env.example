# Shopify App credentials (from partners.shopify.com)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Your app's public URL (Vercel URL or ngrok for dev)
HOST=https://shopify.cipherpay.app

# Upstash Redis
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# CipherPay defaults
CIPHERPAY_API_URL=https://api.cipherpay.app

# --- Payments Extension (Shopify Payments Apps API) ---
# These scopes are auto-granted via the payments extension:
#   write_payment_gateways, write_payment_sessions
#
# mTLS: Shopify requires mutual TLS for production payment endpoints.
# Configure your reverse proxy / CDN to verify Shopify's client cert
# using their CA certificate. See: https://shopify.dev/docs/apps/build/payments/requirements
# SHOPIFY_PAYMENTS_CA_CERT_PATH=/path/to/shopify-payments-ca.pem
