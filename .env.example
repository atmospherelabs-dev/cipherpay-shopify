# Shopify App credentials (from partners.shopify.com)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_orders,write_orders,read_checkouts

# Your app's public URL (Vercel URL or ngrok for dev)
HOST=https://your-app.vercel.app

# CipherPay defaults (merchants override with their own keys)
CIPHERPAY_API_URL=https://api.cipherpay.app
